{
  "manifest_version": 3,
  "name": "Aura - Virtual Try-On",
  "version": "1.0.0",
  "description": "Save clothes from any website and try them on your AI avatar using Google Gemini",
  "permissions": [
    "activeTab",
    "storage",
    "scripting",
    "tabs",
    "identity",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>",
    "https://nsegoojwxdrzeohsvhrd.supabase.co/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
